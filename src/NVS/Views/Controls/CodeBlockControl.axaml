<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="NVS.Views.Controls.CodeBlockControl">

    <Border Background="#1E1E1E" CornerRadius="6" Padding="0" Margin="0,4">
        <Grid RowDefinitions="Auto,*">
            <!-- Header: language + copy + apply buttons -->
            <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="6,6,0,0" Padding="8,4">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0"
                               x:Name="LanguageLabel"
                               Foreground="#808080"
                               FontSize="10"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" x:Name="CopyButton"
                            Content="📋" Padding="4,2" Margin="4,0,0,0"
                            Background="Transparent" Foreground="#AAAAAA" FontSize="11"
                            ToolTip.Tip="Copy code"
                            Click="OnCopyClick" />
                    <Button Grid.Column="2" x:Name="ApplyButton"
                            Content="📝" Padding="4,2" Margin="2,0,0,0"
                            Background="Transparent" Foreground="#AAAAAA" FontSize="11"
                            ToolTip.Tip="Apply to editor"
                            Click="OnApplyClick" />
                </Grid>
            </Border>

            <!-- Code content -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="400">
                <SelectableTextBlock x:Name="CodeText"
                                     FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                                     FontSize="12"
                                     Foreground="#D4D4D4"
                                     Padding="10,8"
                                     TextWrapping="NoWrap" />
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
