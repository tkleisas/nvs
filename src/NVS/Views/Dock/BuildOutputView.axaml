<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dock="clr-namespace:NVS.ViewModels.Dock"
             mc:Ignorable="d"
             x:Class="NVS.Views.Dock.BuildOutputView"
             x:DataType="dock:BuildOutputToolViewModel">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="4,2">
            <Button Content="Clear" FontSize="11" Padding="6,2"
                    Command="{Binding ClearCommand}" />
        </StackPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding OutputLines}"
                          Padding="4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="dock:BuildOutputLine">
                        <TextBlock Text="{ReflectionBinding Text}"
                                   FontFamily="Cascadia Mono,Consolas,Courier New,monospace"
                                   FontSize="12"
                                   Classes.error="{ReflectionBinding IsError}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC" />
        </Style>
        <Style Selector="TextBlock.error">
            <Setter Property="Foreground" Value="#F44747" />
        </Style>
    </UserControl.Styles>
</UserControl>
