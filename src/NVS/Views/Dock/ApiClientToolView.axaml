<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dock="clr-namespace:NVS.ViewModels.Dock"
             xmlns:apiViews="clr-namespace:ApiClient.UI.Views;assembly=ApiClient.UI"
             mc:Ignorable="d"
             x:Class="NVS.Views.Dock.ApiClientToolView"
             x:DataType="dock:ApiClientToolViewModel">

    <apiViews:WorkspaceView DataContext="{Binding ApiClientViewModel}" />
</UserControl>
