<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dock="clr-namespace:NVS.ViewModels.Dock"
             xmlns:terminal="using:Iciclecreek.Terminal"
             mc:Ignorable="d"
             x:Class="NVS.Views.Dock.TerminalView"
             x:DataType="dock:TerminalToolViewModel">

    <terminal:TerminalControl x:Name="Terminal"
                              FontFamily="{Binding TerminalFontFamily}"
                              FontSize="{Binding TerminalFontSize}"
                              BufferSize="{Binding TerminalBufferSize}" />
</UserControl>
