<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dock="clr-namespace:NVS.ViewModels.Dock"
             mc:Ignorable="d"
             x:Class="NVS.Views.Dock.ConflictResolverView"
             x:DataType="dock:ConflictResolverToolViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource ToolPanelBackgroundBrush}" Padding="8,4">
            <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="Bold"
                       Foreground="{DynamicResource TextForegroundBrush}" />
        </Border>

        <!-- Conflict Blocks -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Conflicts}" Margin="8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="dock:ConflictBlockViewModel">
                        <Border BorderBrush="#555" BorderThickness="1" CornerRadius="4"
                                Margin="0,4" Padding="0">

                            <Grid RowDefinitions="Auto,Auto,Auto">
                                <!-- Ours (Current) -->
                                <Border Grid.Row="0" Background="#20F44747" Padding="8,4">
                                    <Grid RowDefinitions="Auto,Auto">
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding OursLabel}" FontWeight="Bold"
                                                       FontSize="11" Foreground="#F44747" />
                                            <Button Content="Accept Current" FontSize="10" Padding="6,2"
                                                    Click="OnAcceptCurrentClick"
                                                    Background="#40F44747" Foreground="White" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{Binding OursText}"
                                                   FontFamily="Consolas,monospace" FontSize="12"
                                                   Foreground="{DynamicResource TextForegroundBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Theirs (Incoming) -->
                                <Border Grid.Row="1" Background="#204EC9B0" Padding="8,4">
                                    <Grid RowDefinitions="Auto,Auto">
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding TheirsLabel}" FontWeight="Bold"
                                                       FontSize="11" Foreground="#4EC9B0" />
                                            <Button Content="Accept Incoming" FontSize="10" Padding="6,2"
                                                    Click="OnAcceptIncomingClick"
                                                    Background="#404EC9B0" Foreground="White" />
                                            <Button Content="Accept Both" FontSize="10" Padding="6,2"
                                                    Click="OnAcceptBothClick"
                                                    Background="#40808080" Foreground="White" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{Binding TheirsText}"
                                                   FontFamily="Consolas,monospace" FontSize="12"
                                                   Foreground="{DynamicResource TextForegroundBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Resolution status -->
                                <Border Grid.Row="2" Background="#20808080" Padding="8,2"
                                        IsVisible="{Binding IsResolved}">
                                    <TextBlock Text="{Binding ResolutionLabel}" FontSize="11"
                                               Foreground="#4EC9B0" FontWeight="Bold" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer: Resolve All button -->
        <Border Grid.Row="2" Background="{DynamicResource ToolPanelBackgroundBrush}" Padding="8,4">
            <Button Content="✓ Apply Resolutions"
                    Command="{Binding ResolveAllCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Background="{DynamicResource AccentBrush}" Foreground="White" Padding="8,4" />
        </Border>
    </Grid>
</UserControl>
