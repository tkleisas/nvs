<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dock="clr-namespace:NVS.ViewModels.Dock"
             mc:Ignorable="d"
             x:Class="NVS.Views.Dock.CodeMetricsView"
             x:DataType="dock:CodeMetricsToolViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="6,4">
            <Button Content="📊 Analyze Workspace" Padding="8,4"
                    Command="{Binding AnalyzeProjectCommand}"
                    IsEnabled="{Binding !IsAnalyzing}"
                    Background="#264F78" Foreground="{DynamicResource EditorForegroundBrush}" FontSize="11" />
            <Button Content="📄 Analyze File" Padding="8,4"
                    Command="{Binding AnalyzeCurrentFileCommand}"
                    IsEnabled="{Binding !IsAnalyzing}"
                    Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource EditorForegroundBrush}" FontSize="11" />
        </StackPanel>

        <!-- Metric tree -->
        <TreeView Grid.Row="1"
                  ItemsSource="{Binding MetricTree}"
                  Background="{DynamicResource ToolPanelBackgroundBrush}" BorderThickness="0"
                  Margin="0,2,0,0">
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True" />
                    <Setter Property="Padding" Value="2,1" />
                </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="dock:MetricTreeNode">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,1">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding Icon}" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource TextForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding Detail}" FontSize="10"
                                   Foreground="#808080" Margin="12,0,8,0"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="2" Text="{Binding MetricValue}" FontSize="10"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,4,0">
                            <TextBlock.Styles>
                                <Style Selector="TextBlock">
                                    <Setter Property="Foreground" Value="#808080" />
                                </Style>
                            </TextBlock.Styles>
                        </TextBlock>
                    </Grid>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="#808080" />
        </Border>
    </Grid>
</UserControl>
