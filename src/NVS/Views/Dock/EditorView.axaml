<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NVS.ViewModels"
             xmlns:dock="clr-namespace:NVS.ViewModels.Dock"
             xmlns:AvaloniaEdit="using:AvaloniaEdit"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:NVS.Behaviors"
             xmlns:controls="using:NVS.Controls"
             mc:Ignorable="d"
             x:Class="NVS.Views.Dock.EditorView"
             x:DataType="dock:EditorDocumentViewModel">

    <Grid>
        <!-- Primary Editor Pane -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0"
                    ItemsSource="{Binding Main.Editor.OpenDocuments}"
                    SelectedIndex="{Binding Main.Editor.ActiveTabIndex}"
                    Background="{DynamicResource ToolPanelBackgroundBrush}"
                    BorderThickness="0">
            <TabControl.ItemTemplate>
                <DataTemplate DataType="vm:DocumentViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center"/>
                        <Button Command="{Binding CloseTabCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="2"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Width="16" Height="16">
                            <TextBlock Text="✕" FontSize="10" Foreground="#808080"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="vm:DocumentViewModel">
                    <Grid ColumnDefinitions="*,Auto">
                    <AvaloniaEdit:TextEditor
                        Grid.Column="0"
                        behaviors:TextEditorSyntaxHighlighting.Language="{Binding Language}"
                        ShowLineNumbers="True"
                        FontFamily="Consolas,Courier New,monospace"
                        FontSize="14"
                        Background="{DynamicResource ToolPanelBackgroundBrush}"
                        Foreground="{DynamicResource EditorForegroundBrush}"
                        BorderThickness="0"
                        Padding="8"
                        WordWrap="False">
                        <AvaloniaEdit:TextEditor.ContextMenu>
                            <ContextMenu Opened="OnContextMenuOpened">
                                <MenuItem Header="Cut" InputGesture="Ctrl+X" Click="OnCutClick"/>
                                <MenuItem Header="Copy" InputGesture="Ctrl+C" Click="OnCopyClick"/>
                                <MenuItem Header="Paste" InputGesture="Ctrl+V" Click="OnPasteClick"/>
                                <Separator/>
                                <MenuItem Header="Select All" InputGesture="Ctrl+A" Click="OnSelectAllClick"/>
                                <Separator/>
                                <MenuItem Header="Undo" InputGesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
                                <MenuItem Header="Redo" InputGesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
                                <Separator/>
                                <MenuItem Header="Find" InputGesture="Ctrl+F" Command="{Binding OpenSearchCommand}"/>
                                <MenuItem Header="Go to Definition" InputGesture="F12" Command="{Binding GoToDefinitionCommand}"/>
                                <MenuItem Header="Quick Fix..." InputGesture="Ctrl+OemPeriod" Tag="QuickFix" Click="OnQuickFixClick"/>
                                <Separator Tag="SqlSeparator" IsVisible="False"/>
                                <MenuItem Tag="ExecuteSql" Header="Execute SQL in Database Explorer" Click="OnExecuteInDatabaseExplorerClick" IsVisible="False"/>
                                <Separator/>
                                <MenuItem Header="Split Right" Click="OnSplitRightClick"/>
                                <MenuItem Header="Split Down" Click="OnSplitDownClick"/>
                                <MenuItem Header="Close Split" Click="OnCloseSplitClick" Tag="CloseSplit" IsVisible="False"/>
                            </ContextMenu>
                        </AvaloniaEdit:TextEditor.ContextMenu>
                        <i:Interaction.Behaviors>
                            <behaviors:DocumentTextBindingBehavior
                                Text="{Binding Text, Mode=TwoWay}"
                                Line="{Binding CursorLine, Mode=TwoWay}"
                                Column="{Binding CursorColumn, Mode=OneWayToSource}"
                                UndoCommand="{Binding UndoCommand, Mode=OneWayToSource}"
                                RedoCommand="{Binding RedoCommand, Mode=OneWayToSource}"
                                OpenSearchCommand="{Binding OpenSearchCommand, Mode=OneWayToSource}"
                                Diagnostics="{Binding Diagnostics}"
                                GoToDefinitionCommand="{Binding GoToDefinitionCommand}"
                                RequestCompletionCommand="{Binding RequestCompletionCommand}"
                                CompletionResults="{Binding LastCompletionResults}"
                                RequestSignatureHelpCommand="{Binding RequestSignatureHelpCommand}"
                                SignatureHelpResult="{Binding LastSignatureHelp}"
                                Breakpoints="{Binding Breakpoints}"
                                ToggleBreakpointCommand="{Binding ToggleBreakpointCommand}"
                                DebugCurrentLine="{Binding DebugCurrentLine}"
                                DebugEvaluateFunc="{Binding DebugEvaluateFunc}"
                                FileMethodMetrics="{Binding FileMethodMetrics}"
                                InlineCompletionFunc="{Binding InlineCompletionFunc}"/>
                        </i:Interaction.Behaviors>
                    </AvaloniaEdit:TextEditor>
                    <controls:MinimapControl Grid.Column="1" Width="80" Name="Minimap"/>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- Split Splitter -->
        <GridSplitter Grid.Column="1" Width="4"
                      Background="{DynamicResource BorderBrush}"
                      IsVisible="{Binding Main.Editor.IsSplitActive}"/>

        <!-- Split Editor Pane -->
        <TabControl Grid.Column="2"
                    ItemsSource="{Binding Main.Editor.OpenDocuments}"
                    SelectedIndex="{Binding Main.Editor.SplitTabIndex}"
                    Background="{DynamicResource ToolPanelBackgroundBrush}"
                    BorderThickness="0"
                    IsVisible="{Binding Main.Editor.IsSplitActive}">
            <TabControl.ItemTemplate>
                <DataTemplate DataType="vm:DocumentViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="vm:DocumentViewModel">
                    <Grid ColumnDefinitions="*,Auto">
                    <AvaloniaEdit:TextEditor
                        Grid.Column="0"
                        behaviors:TextEditorSyntaxHighlighting.Language="{Binding Language}"
                        ShowLineNumbers="True"
                        FontFamily="Consolas,Courier New,monospace"
                        FontSize="14"
                        Background="{DynamicResource ToolPanelBackgroundBrush}"
                        Foreground="{DynamicResource EditorForegroundBrush}"
                        BorderThickness="0"
                        Padding="8"
                        WordWrap="False"
                        IsReadOnly="True">
                        <i:Interaction.Behaviors>
                            <behaviors:DocumentTextBindingBehavior
                                Text="{Binding Text, Mode=OneWay}"
                                Line="{Binding CursorLine, Mode=OneWay}"
                                Column="{Binding CursorColumn, Mode=OneWay}"
                                Diagnostics="{Binding Diagnostics}"
                                Breakpoints="{Binding Breakpoints}"
                                DebugCurrentLine="{Binding DebugCurrentLine}"/>
                        </i:Interaction.Behaviors>
                    </AvaloniaEdit:TextEditor>
                    <controls:MinimapControl Grid.Column="1" Width="80"/>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- Empty State -->
        <Border Grid.ColumnSpan="3" Background="{DynamicResource ToolPanelBackgroundBrush}"
                IsVisible="{Binding Main.Editor.HasNoOpenDocuments}">
            <StackPanel HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Spacing="16">
                <TextBlock Text="NVS"
                          FontSize="48"
                          FontWeight="Bold"
                          Foreground="{DynamicResource AccentBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="No Vim Substitute (We're Honest)"
                          FontSize="18"
                          Foreground="{DynamicResource TextForegroundBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Press Ctrl+O to open a file or Ctrl+Shift+O to open a folder"
                          FontSize="14"
                          Foreground="#808080"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
