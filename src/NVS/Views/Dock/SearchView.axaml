<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NVS.ViewModels"
             xmlns:dock="clr-namespace:NVS.ViewModels.Dock"
             mc:Ignorable="d"
             x:Class="NVS.Views.Dock.SearchView"
             x:DataType="dock:SearchToolViewModel">

    <Grid RowDefinitions="Auto,*" Margin="8,4">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
            <TextBox Grid.Column="0"
                     Text="{Binding Main.SearchQuery}"
                     Watermark="Search in files..."
                     Background="#3C3C3C"
                     Foreground="#CCCCCC"
                     BorderBrush="#555"
                     FontSize="12"
                     Padding="6,4"
                     KeyDown="OnSearchQueryKeyDown" />
            <Button Grid.Column="1" Content="🔍" Padding="6,4" Margin="4,0,0,0"
                    Command="{Binding Main.SearchFilesCommand}"
                    Background="#3C3C3C" Foreground="#CCCCCC" />
        </Grid>
        <Border Grid.Row="1" IsVisible="{Binding Main.IsSearching}"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8">
            <TextBlock Text="Searching..." Foreground="#808080" FontSize="12" />
        </Border>
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Main.SearchResults}"
                 Background="Transparent"
                 BorderThickness="0"
                 DoubleTapped="OnSearchResultDoubleTapped">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="2,1"/>
                    <Setter Property="MinHeight" Value="20"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:FileSearchResult">
                    <StackPanel Spacing="0" Margin="0,1">
                        <TextBlock Text="{Binding Display}" FontSize="11"
                                   Foreground="#569CD6"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding LineText}" FontSize="11"
                                   Foreground="#808080"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
