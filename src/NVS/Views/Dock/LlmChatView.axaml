<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dock="clr-namespace:NVS.ViewModels.Dock"
             xmlns:models="clr-namespace:NVS.Core.Models;assembly=NVS.Core"
             xmlns:controls="clr-namespace:NVS.Views.Controls"
             mc:Ignorable="d"
             x:Class="NVS.Views.Dock.LlmChatView"
             x:DataType="dock:LlmChatToolViewModel">

    <UserControl.Styles>
        <Style Selector="Border.user-bubble">
            <Setter Property="Background" Value="#264F78" />
            <Setter Property="CornerRadius" Value="8,8,2,8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="40,2,4,2" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        <Style Selector="Border.assistant-bubble">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="CornerRadius" Value="8,8,8,2" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="4,2,40,2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Border.system-bubble">
            <Setter Property="Background" Value="#3C2A1A" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="20,2" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.tool-bubble">
            <Setter Property="Background" Value="#1A2F1A" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Margin" Value="20,1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">

        <!-- Session bar: dropdown + new/delete -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="6,4,6,0">
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Sessions}"
                      SelectedItem="{Binding CurrentSession}"
                      Background="#2D2D2D"
                      Foreground="{DynamicResource TextForegroundBrush}"
                      FontSize="11"
                      MinWidth="100"
                      Padding="4,2"
                      ToolTip.Tip="Switch chat session">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatSession">
                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" MaxWidth="200" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="1" Content="+" Padding="6,2" Margin="4,0,0,0"
                    Command="{Binding NewSessionCommand}"
                    Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="12" FontWeight="Bold"
                    ToolTip.Tip="New chat session" />
            <Button Grid.Column="2" Content="🗑" Padding="4,2" Margin="4,0,0,0"
                    Command="{Binding DeleteSessionCommand}"
                    Background="{DynamicResource InputBackgroundBrush}" Foreground="#FF6B68" FontSize="11"
                    ToolTip.Tip="Delete current session" />
        </Grid>

        <!-- Top bar: task mode + clear + stop -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="6,4">
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding TaskModes}"
                      SelectedItem="{Binding SelectedTaskMode}"
                      Background="#2D2D2D"
                      Foreground="{DynamicResource TextForegroundBrush}"
                      FontSize="11"
                      MinWidth="100"
                      Padding="4,2"
                      ToolTip.Tip="System prompt mode" />
            <Button Grid.Column="1" Content="🧹" Padding="4,2" Margin="4,0,0,0"
                    Command="{Binding ClearChatCommand}"
                    Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="11"
                    ToolTip.Tip="Clear chat" />
            <Button Grid.Column="2" Content="⏹" Padding="4,2" Margin="4,0,0,0"
                    Command="{Binding StopCommand}"
                    Background="{DynamicResource InputBackgroundBrush}" Foreground="#FF6B68" FontSize="11"
                    ToolTip.Tip="Stop generation" />
        </Grid>

        <!-- Messages list -->
        <ScrollViewer Grid.Row="2" x:Name="MessageScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Messages}" Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="dock:ChatBubble">
                        <Panel>
                            <!-- User bubble -->
                            <Border Classes="user-bubble"
                                    IsVisible="{Binding IsUser}">
                                <SelectableTextBlock Text="{Binding Content}"
                                                     Foreground="#E0E0E0"
                                                     FontSize="12"
                                                     TextWrapping="Wrap" />
                            </Border>
                            <!-- Assistant bubble -->
                            <Border Classes="assistant-bubble"
                                    IsVisible="{Binding IsAssistant}">
                                <controls:ChatContentPresenter ContentText="{Binding Content}" />
                            </Border>
                            <!-- System bubble -->
                            <Border Classes="system-bubble"
                                    IsVisible="{Binding IsSystem}">
                                <TextBlock Text="{Binding Content}"
                                           Foreground="#D19A66"
                                           FontSize="11"
                                           FontStyle="Italic"
                                           TextWrapping="Wrap" />
                            </Border>
                            <!-- Tool call bubble -->
                            <Border Classes="tool-bubble"
                                    IsVisible="{Binding IsTool}">
                                <TextBlock Text="{Binding Content}"
                                           Foreground="#98C379"
                                           FontSize="10"
                                           FontFamily="Cascadia Code,Consolas,Courier New"
                                           TextWrapping="Wrap" />
                            </Border>
                        </Panel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Attached files indicator -->
        <ItemsControl Grid.Row="3" ItemsSource="{Binding AttachedFiles}"
                      Margin="6,2,6,0"
                      IsVisible="{Binding AttachedFiles.Count}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Background="#2D3748" CornerRadius="4" Padding="4,2" Margin="0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding}"
                                       Foreground="#90CAF9" FontSize="10"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="✕" Padding="2,0"
                                    Background="Transparent" Foreground="#808080" FontSize="9"
                                    Command="{Binding $parent[UserControl].((dock:LlmChatToolViewModel)DataContext).RemoveAttachedFileCommand}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Input area -->
        <Grid Grid.Row="4" ColumnDefinitions="Auto,Auto,*,Auto" Margin="6,2,6,2">
            <Button Grid.Column="0"
                    Content="📎" Padding="6,6"
                    Background="Transparent" Foreground="#AAAAAA" FontSize="14"
                    Command="{Binding AttachFileCommand}"
                    VerticalAlignment="Bottom"
                    ToolTip.Tip="Attach file for context" />
            <Button Grid.Column="1"
                    Content="📷" Padding="6,6"
                    Background="Transparent" Foreground="#AAAAAA" FontSize="14"
                    Command="{Binding AttachImageCommand}"
                    IsVisible="{Binding SupportsVision}"
                    VerticalAlignment="Bottom"
                    ToolTip.Tip="Attach image (vision)" />
            <TextBox Grid.Column="2"
                     Text="{Binding UserInput}"
                     Watermark="Ask anything..."
                     Background="{DynamicResource ToolPanelBackgroundBrush}"
                     Foreground="{DynamicResource EditorForegroundBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     FontSize="12"
                     Padding="8,6"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxHeight="120"
                     KeyDown="OnInputKeyDown" />
            <Button Grid.Column="3"
                    Content="➤"
                    Command="{Binding SendMessageCommand}"
                    Background="#264F78"
                    Foreground="#FFFFFF"
                    FontSize="14"
                    Padding="10,6"
                    Margin="4,0,0,0"
                    VerticalAlignment="Bottom"
                    ToolTip.Tip="Send (Enter)" />
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="5" Background="{DynamicResource SidebarBackgroundBrush}" Padding="6,3">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#808080"
                       FontSize="10" />
        </Border>
    </Grid>
</UserControl>
