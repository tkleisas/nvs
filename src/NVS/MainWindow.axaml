<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NVS.ViewModels"
        xmlns:core="clr-namespace:NVS.Core.Interfaces;assembly=NVS.Core"
        xmlns:AvaloniaEdit="using:AvaloniaEdit"
        xmlns:i="using:Avalonia.Xaml.Interactivity"
        xmlns:behaviors="using:NVS.Behaviors"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="NVS.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding Title}"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#2D2D30">
            <MenuItem Header="_File">
                <MenuItem Header="_New File" InputGesture="Ctrl+N" Command="{Binding NewFileCommand}" />
                <MenuItem Header="_Open File..." InputGesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
                <MenuItem Header="Open _Folder..." InputGesture="Ctrl+Shift+O" Command="{Binding OpenFolderCommand}" />
                <Separator />
                <MenuItem Header="_Save" InputGesture="Ctrl+S" Command="{Binding SaveFileCommand}" />
                <MenuItem Header="Save _As..." InputGesture="Ctrl+Shift+S" />
                <MenuItem Header="Save A_ll" Command="{Binding SaveAllCommand}" />
                <Separator />
                <MenuItem Header="_Close" InputGesture="Ctrl+W" Command="{Binding CloseFileCommand}" />
                <MenuItem Header="Close All" />
                <Separator />
                <MenuItem Header="E_xit" InputGesture="Alt+F4" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGesture="Ctrl+Z" Command="{Binding Editor.UndoCommand}" />
                <MenuItem Header="_Redo" InputGesture="Ctrl+Y" Command="{Binding Editor.RedoCommand}" />
                <Separator />
                <MenuItem Header="Cu_t" InputGesture="Ctrl+X" />
                <MenuItem Header="_Copy" InputGesture="Ctrl+C" />
                <MenuItem Header="_Paste" InputGesture="Ctrl+V" />
                <Separator />
                <MenuItem Header="_Find" InputGesture="Ctrl+F" Command="{Binding Editor.FindCommand}" />
                <MenuItem Header="_Replace" InputGesture="Ctrl+H" Command="{Binding Editor.FindCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Explorer" InputGesture="Ctrl+Shift+E" />
                <MenuItem Header="_Search" InputGesture="Ctrl+Shift+F" />
                <MenuItem Header="_Source Control" InputGesture="Ctrl+Shift+G" />
                <Separator />
                <MenuItem Header="_Output" InputGesture="Ctrl+Shift+U" />
                <MenuItem Header="_Terminal" Command="{Binding ToggleTerminalCommand}" InputGesture="Ctrl+OemTilde" />
            </MenuItem>
            <MenuItem Header="_Go">
                <MenuItem Header="Go to _File..." InputGesture="Ctrl+P" />
                <MenuItem Header="Go to _Symbol..." InputGesture="Ctrl+Shift+O" />
                <MenuItem Header="Go to _Line..." InputGesture="Ctrl+G" />
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="_Start Debugging" InputGesture="F5" />
                <MenuItem Header="Start _Without Debugging" InputGesture="Ctrl+F5" />
                <MenuItem Header="_Stop" InputGesture="Shift+F5" />
                <Separator />
                <MenuItem Header="Toggle _Breakpoint" InputGesture="F9" />
            </MenuItem>
            <MenuItem Header="_Terminal">
                <MenuItem Header="_New Terminal" InputGesture="Ctrl+Shift+OemTilde" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About NVS" Click="OnAboutClick" />
                <MenuItem Header="_Report Issue" />
            </MenuItem>
            <MenuItem Header="_Settings" Click="OnSettingsClick" />
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#2D2D30" Padding="4">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Width="28" Height="28" ToolTip.Tip="New File" Command="{Binding NewFileCommand}">
                    <TextBlock Text="+" FontSize="14" Foreground="#CCCCCC" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Open File" Command="{Binding OpenFileCommand}">
                    <TextBlock Text="&#x1F4C2;" FontSize="12" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Save" Command="{Binding SaveFileCommand}">
                    <TextBlock Text="&#x1F4BE;" FontSize="12" />
                </Button>
                <Border Width="1" Background="#555" Margin="4,2" />
                <Button Width="28" Height="28" ToolTip.Tip="Undo" Command="{Binding Editor.UndoCommand}">
                    <TextBlock Text="&#x21B6;" FontSize="12" Foreground="#CCCCCC" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Redo" Command="{Binding Editor.RedoCommand}">
                    <TextBlock Text="&#x21B7;" FontSize="12" Foreground="#CCCCCC" />
                </Button>
                <Border Width="1" Background="#555" Margin="4,2" />
                <Button Width="28" Height="28" ToolTip.Tip="Start Debugging">
                    <TextBlock Text="&#x25B6;" FontSize="12" Foreground="#4EC9B0" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Stop">
                    <TextBlock Text="&#x25A0;" FontSize="12" Foreground="#F44747" />
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*">
            <!-- Sidebar -->
            <Border Grid.Column="0" Width="250" Background="#252526"
                    BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <!-- Sidebar Tab Buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2D2D30">
                        <Button Padding="12,8" Background="Transparent" BorderThickness="0"
                                Command="{Binding ShowExplorerCommand}"
                                ToolTip.Tip="Explorer (Ctrl+Shift+E)">
                            <TextBlock Text="📁 EXPLORER" FontWeight="Bold" FontSize="11"
                                       Foreground="#CCCCCC"
                                       Opacity="{Binding IsSidebarShowingExplorer, Converter={x:Static vm:BoolToOpacityConverter.Instance}}" />
                        </Button>
                        <Button Padding="12,8" Background="Transparent" BorderThickness="0"
                                Command="{Binding ShowSourceControlCommand}"
                                ToolTip.Tip="Source Control (Ctrl+Shift+G)">
                            <TextBlock Text="🔀 GIT" FontWeight="Bold" FontSize="11"
                                       Foreground="#CCCCCC"
                                       Opacity="{Binding IsSidebarShowingGit, Converter={x:Static vm:BoolToOpacityConverter.Instance}}" />
                        </Button>
                    </StackPanel>

                    <!-- Explorer Panel -->
                    <TreeView Grid.Row="1" Padding="4" Background="Transparent"
                              ItemsSource="{Binding FileTree}"
                              DoubleTapped="OnFileTreeDoubleTapped"
                              IsVisible="{Binding IsSidebarShowingExplorer}">
                        <TreeView.Resources>
                            <x:Double x:Key="TreeViewItemIndent">12</x:Double>
                        </TreeView.Resources>
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="22"/>
                            </Style>
                        </TreeView.Styles>
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate DataType="vm:FileTreeNode" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1">
                                    <TextBlock Text="{Binding Icon}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#CCCCCC" VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- Source Control Panel -->
                    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*,Auto,Auto,*"
                          IsVisible="{Binding IsSidebarShowingGit}"
                          Margin="8,4">
                        <!-- Commit message + button -->
                        <TextBox Grid.Row="0"
                                 Text="{Binding CommitMessage}"
                                 Watermark="Commit message"
                                 AcceptsReturn="True"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 Background="#3C3C3C"
                                 Foreground="#CCCCCC"
                                 BorderBrush="#555" />
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,4">
                            <Button Grid.Column="0" Content="✓ Commit" 
                                    Command="{Binding GitCommitCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Background="#007ACC" Foreground="White" Padding="8,4" />
                            <Button Grid.Column="1" Content="⟳" Margin="4,0,0,0"
                                    Command="{Binding GitRefreshCommand}"
                                    ToolTip.Tip="Refresh"
                                    Background="#3C3C3C" Foreground="#CCCCCC" Padding="8,4" />
                        </Grid>

                        <!-- Staged Changes -->
                        <TextBlock Grid.Row="2" Text="STAGED CHANGES"
                                   FontWeight="Bold" FontSize="11" Foreground="#CCCCCC"
                                   Margin="0,8,0,4"
                                   VerticalAlignment="Top" />
                        <ItemsControl Grid.Row="3" ItemsSource="{Binding GitStagedFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="core:GitFileStatus">
                                    <Grid ColumnDefinitions="Auto,*" Margin="0,1">
                                        <TextBlock Grid.Column="0" Text="{Binding Status}" FontSize="10"
                                                   Foreground="#4EC9B0" Width="16" Margin="0,0,4,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                   FontSize="12" Foreground="#4EC9B0"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Changes -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,4"
                                    Spacing="4">
                            <TextBlock Text="CHANGES"
                                       FontWeight="Bold" FontSize="11" Foreground="#CCCCCC" />
                            <Button Content="+" FontSize="10" Padding="4,0"
                                    Command="{Binding GitStageAllCommand}"
                                    ToolTip.Tip="Stage All"
                                    Background="Transparent" Foreground="#CCCCCC" />
                        </StackPanel>
                        <ItemsControl Grid.Row="5" ItemsSource="{Binding GitChangedFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="core:GitFileStatus">
                                    <Grid ColumnDefinitions="Auto,*" Margin="0,1">
                                        <TextBlock Grid.Column="0" Text="{Binding Status}" FontSize="10"
                                                   Foreground="#D7BA7D" Width="16" Margin="0,0,4,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                   FontSize="12" Foreground="#D7BA7D"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>

            <!-- Editor Area -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*">
                <!-- Tabs -->
                <TabControl Grid.Row="0" Grid.RowSpan="2"
                            ItemsSource="{Binding Editor.OpenDocuments}"
                            SelectedIndex="{Binding Editor.ActiveTabIndex}"
                            Background="#1E1E1E"
                            BorderThickness="0">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="vm:DocumentViewModel">
                            <TextBlock Text="{Binding Title}" FontSize="12"/>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                        <DataTemplate DataType="vm:DocumentViewModel">
                            <AvaloniaEdit:TextEditor
                                behaviors:TextEditorSyntaxHighlighting.Language="{Binding Language}"
                                ShowLineNumbers="True"
                                FontFamily="Consolas,Courier New,monospace"
                                FontSize="14"
                                Background="#1E1E1E"
                                Foreground="#D4D4D4"
                                BorderThickness="0"
                                Padding="8"
                                WordWrap="False">
                                <i:Interaction.Behaviors>
                                    <behaviors:DocumentTextBindingBehavior
                                        Text="{Binding Text, Mode=TwoWay}"
                                        Line="{Binding CursorLine, Mode=OneWayToSource}"
                                        Column="{Binding CursorColumn, Mode=OneWayToSource}"
                                        UndoCommand="{Binding UndoCommand, Mode=OneWayToSource}"
                                        RedoCommand="{Binding RedoCommand, Mode=OneWayToSource}"
                                        OpenSearchCommand="{Binding OpenSearchCommand, Mode=OneWayToSource}"
                                        Diagnostics="{Binding Diagnostics}"
                                        GoToDefinitionCommand="{Binding GoToDefinitionCommand}"
                                        RequestCompletionCommand="{Binding RequestCompletionCommand}"
                                        CompletionResults="{Binding LastCompletionResults}"/>
                                </i:Interaction.Behaviors>
                            </AvaloniaEdit:TextEditor>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
                
                <!-- Empty State -->
                <Border Grid.Row="0" Grid.RowSpan="2" Background="#1E1E1E" 
                       IsVisible="{Binding Editor.HasNoOpenDocuments}">
                    <StackPanel HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               Spacing="16">
                        <TextBlock Text="NVS" 
                                  FontSize="48" 
                                  FontWeight="Bold"
                                  Foreground="#007ACC"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="No Vim Substitute (We're Honest)" 
                                  FontSize="18" 
                                  Foreground="#CCCCCC"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Press Ctrl+O to open a file or Ctrl+Shift+O to open a folder"
                                  FontSize="14" 
                                  Foreground="#808080"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Terminal Panel -->
        <Border Grid.Row="3" IsVisible="{Binding IsTerminalVisible}"
                Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0">
            <Grid RowDefinitions="Auto,*,Auto" Height="200">
                <!-- Terminal header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Background="#2D2D30" Margin="0,0,0,0">
                    <TextBlock Grid.Column="0" Text="TERMINAL" FontWeight="Bold" FontSize="11"
                               Foreground="#CCCCCC" Padding="8,4" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="+" Padding="8,4"
                            Command="{Binding NewTerminalCommand}"
                            ToolTip.Tip="New Terminal"
                            Background="Transparent" Foreground="#CCCCCC" FontSize="12" />
                    <Button Grid.Column="2" Content="✕" Padding="8,4"
                            Command="{Binding CloseTerminalCommand}"
                            ToolTip.Tip="Close Terminal"
                            Background="Transparent" Foreground="#CCCCCC" FontSize="12" />
                </Grid>
                <!-- Terminal output -->
                <TextBox Grid.Row="1"
                         Text="{Binding TerminalOutput}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         Background="#1E1E1E"
                         Foreground="#CCCCCC"
                         BorderThickness="0"
                         FontFamily="Consolas,Courier New,monospace"
                         FontSize="12"
                         Padding="8,4" />
                <!-- Terminal input -->
                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Background="#252526">
                    <TextBox Grid.Column="0"
                             Text="{Binding TerminalInput}"
                             Watermark="Type a command..."
                             Background="Transparent"
                             Foreground="#CCCCCC"
                             BorderThickness="0"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="12"
                             Padding="8,4"
                             KeyDown="OnTerminalInputKeyDown" />
                    <Button Grid.Column="1" Content="▶" Padding="8,4"
                            Command="{Binding SendTerminalInputCommand}"
                            Background="Transparent" Foreground="#4EC9B0" />
                </Grid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="#007ACC" Padding="8,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding CurrentBranch}" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="|" Foreground="#80FFFFFF" />
                    <TextBlock Text="{Binding Editor.DiagnosticSummary}" Foreground="White" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" HorizontalAlignment="Center" Foreground="White" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding Editor.CursorLine, StringFormat='Ln {0}'}" Foreground="White" />
                    <TextBlock Text="{Binding Editor.CursorColumn, StringFormat='Col {0}'}" Foreground="White" />
                    <TextBlock Text="Spaces: 4" Foreground="White" />
                    <TextBlock Text="UTF-8" Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
