<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NVS.ViewModels"
        xmlns:dc="using:Dock.Avalonia.Controls"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="NVS.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding Title}"
        MinWidth="800" MinHeight="600"
        Background="#1E1E1E">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewFileCommand}" />
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveFileCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveFileAsCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseFileCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding ShowExplorerCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+F" Command="{Binding ShowSearchCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+G" Command="{Binding ShowSourceControlCommand}" />
        <KeyBinding Gesture="Ctrl+OemTilde" Command="{Binding ToggleTerminalCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+B" Command="{Binding BuildSolutionCommand}" />
        <KeyBinding Gesture="Ctrl+F5" Command="{Binding RunProjectCommand}" />
        <KeyBinding Gesture="F5" Command="{Binding StartDebuggingCommand}" />
        <KeyBinding Gesture="Shift+F5" Command="{Binding StopDebuggingCommand}" />
        <KeyBinding Gesture="F10" Command="{Binding DebugStepOverCommand}" />
        <KeyBinding Gesture="F11" Command="{Binding DebugStepIntoCommand}" />
        <KeyBinding Gesture="Shift+F11" Command="{Binding DebugStepOutCommand}" />
        <KeyBinding Gesture="F9" Command="{Binding ToggleBreakpointCommand}" />
        <KeyBinding Gesture="F1" Command="{Binding ShowHelpCommand}" />
    </Window.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#2D2D30">
            <MenuItem Header="_File">
                <MenuItem Header="_New File" InputGesture="Ctrl+N" Command="{Binding NewFileCommand}" />
                <MenuItem Header="New _Project..." InputGesture="Ctrl+Shift+N" Click="OnNewProjectClick" />
                <MenuItem Header="New File from _Template..." Click="OnNewFileFromTemplateClick" />
                <MenuItem Header="_Add Project to Solution..." Click="OnAddProjectToSolutionClick" />
                <Separator />
                <MenuItem Header="_Open File..." InputGesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
                <MenuItem Header="Open _Solution..." Command="{Binding OpenSolutionCommand}" />
                <MenuItem Header="Open _Folder..." InputGesture="Ctrl+Shift+O" Command="{Binding OpenFolderCommand}" />
                <Separator />
                <MenuItem Header="_Save" InputGesture="Ctrl+S" Command="{Binding SaveFileCommand}" />
                <MenuItem Header="Save _As..." InputGesture="Ctrl+Shift+S" Command="{Binding SaveFileAsCommand}" />
                <MenuItem Header="Save A_ll" Command="{Binding SaveAllCommand}" />
                <Separator />
                <MenuItem Header="_Close" InputGesture="Ctrl+W" Command="{Binding CloseFileCommand}" />
                <MenuItem Header="Close All" Command="{Binding CloseAllFilesCommand}" />
                <Separator />
                <MenuItem Header="E_xit" InputGesture="Alt+F4" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGesture="Ctrl+Z" Command="{Binding Editor.UndoCommand}" />
                <MenuItem Header="_Redo" InputGesture="Ctrl+Y" Command="{Binding Editor.RedoCommand}" />
                <Separator />
                <MenuItem Header="Cu_t" InputGesture="Ctrl+X" />
                <MenuItem Header="_Copy" InputGesture="Ctrl+C" />
                <MenuItem Header="_Paste" InputGesture="Ctrl+V" />
                <Separator />
                <MenuItem Header="_Find" InputGesture="Ctrl+F" Command="{Binding Editor.FindCommand}" />
                <MenuItem Header="_Replace" InputGesture="Ctrl+H" Command="{Binding Editor.FindCommand}" />
                <MenuItem Header="Go to _Line..." InputGesture="Ctrl+G" Click="OnGoToLineClick" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Explorer" InputGesture="Ctrl+Shift+E" Command="{Binding ShowExplorerCommand}" />
                <MenuItem Header="_Search" InputGesture="Ctrl+Shift+F" Command="{Binding ShowSearchCommand}" />
                <MenuItem Header="_Source Control" InputGesture="Ctrl+Shift+G" Command="{Binding ShowSourceControlCommand}" />
                <MenuItem Header="_Database Explorer" Command="{Binding ShowDatabaseExplorerCommand}" />
                <MenuItem Header="_Code Metrics" Command="{Binding ShowCodeMetricsCommand}" />
                <Separator />
                <MenuItem Header="_Terminal" Command="{Binding ToggleTerminalCommand}" InputGesture="Ctrl+OemTilde" />
            </MenuItem>
            <MenuItem Header="_Build">
                <MenuItem Header="_Build Solution" InputGesture="Ctrl+Shift+B" Command="{Binding BuildSolutionCommand}" />
                <MenuItem Header="_Rebuild Solution" Command="{Binding RebuildSolutionCommand}" />
                <MenuItem Header="_Clean Solution" Command="{Binding CleanSolutionCommand}" />
                <Separator />
                <MenuItem Header="_Run Without Debugging" InputGesture="Ctrl+F5" Command="{Binding RunProjectCommand}" />
                <MenuItem Header="_Stop" Command="{Binding StopExecutionCommand}" />
            </MenuItem>
            <MenuItem Header="_Debug">
                <MenuItem Header="_Start Debugging" InputGesture="F5" Command="{Binding StartDebuggingCommand}" />
                <MenuItem Header="S_top Debugging" InputGesture="Shift+F5" Command="{Binding StopDebuggingCommand}" />
                <Separator />
                <MenuItem Header="Step _Over" InputGesture="F10" Command="{Binding DebugStepOverCommand}" />
                <MenuItem Header="Step _Into" InputGesture="F11" Command="{Binding DebugStepIntoCommand}" />
                <MenuItem Header="Step O_ut" InputGesture="Shift+F11" Command="{Binding DebugStepOutCommand}" />
                <Separator />
                <MenuItem Header="_Continue" Command="{Binding DebugContinueCommand}" />
                <MenuItem Header="_Pause" Command="{Binding DebugPauseCommand}" />
                <Separator />
                <MenuItem Header="Toggle _Breakpoint" InputGesture="F9" Command="{Binding ToggleBreakpointCommand}" />
            </MenuItem>
            <MenuItem Header="_Git">
                <MenuItem Header="_Init Repository" Command="{Binding GitInitRepositoryCommand}" />
                <Separator />
                <MenuItem Header="_Pull" Command="{Binding GitPullCommand}" />
                <MenuItem Header="P_ush" Command="{Binding GitPushCommand}" />
                <MenuItem Header="_Fetch" Command="{Binding GitFetchCommand}" />
                <Separator />
                <MenuItem Header="_Stash Changes" Command="{Binding GitStashSaveCommand}" />
                <MenuItem Header="S_tash Pop" Command="{Binding GitStashPopCommand}" />
                <Separator />
                <MenuItem Header="_Refresh" InputGesture="Ctrl+Shift+G" Command="{Binding GitRefreshCommand}" />
            </MenuItem>
            <MenuItem Header="_Terminal">
                <MenuItem Header="_New Terminal" InputGesture="Ctrl+Shift+OemTilde" Command="{Binding NewTerminalCommand}" />
            </MenuItem>
            <MenuItem Header="_Settings" Click="OnSettingsClick" />
            <MenuItem Header="_Help">
                <MenuItem Header="_Welcome" Command="{Binding ShowWelcomeCommand}" />
                <MenuItem Header="_Search Help" InputGesture="F1" Command="{Binding ShowHelpCommand}" />
                <Separator />
                <MenuItem Header="_About NVS" Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#2D2D30" Padding="4">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Width="28" Height="28" ToolTip.Tip="New File" Command="{Binding NewFileCommand}">
                    <PathIcon Width="14" Height="14" Foreground="#CCCCCC"
                              Data="M 6,1 L 8,1 L 8,6 L 13,6 L 13,8 L 8,8 L 8,13 L 6,13 L 6,8 L 1,8 L 1,6 L 6,6 Z" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Open File" Command="{Binding OpenFileCommand}">
                    <PathIcon Width="14" Height="14" Foreground="#CCCCCC"
                              Data="M 1,4 L 5,4 L 6.5,2 L 13,2 L 13,11 L 1,11 Z" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Save" Command="{Binding SaveFileCommand}">
                    <PathIcon Width="14" Height="14" Foreground="#CCCCCC"
                              Data="M 1,1 L 10,1 L 13,4 L 13,13 L 1,13 Z M 4,1 L 4,5 L 9,5 L 9,1 M 3,8 L 11,8 L 11,12 L 3,12 Z" />
                </Button>
                <Border Width="1" Background="#555" Margin="4,2" />
                <Button Width="28" Height="28" ToolTip.Tip="Undo" Command="{Binding Editor.UndoCommand}">
                    <TextBlock Text="&#x21B6;" FontSize="14" Foreground="#CCCCCC" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Redo" Command="{Binding Editor.RedoCommand}">
                    <TextBlock Text="&#x21B7;" FontSize="14" Foreground="#CCCCCC" />
                </Button>
                <Border Width="1" Background="#555" Margin="4,2" />
                <Button Width="28" Height="28" ToolTip.Tip="Build (Ctrl+Shift+B)"
                        Command="{Binding BuildSolutionCommand}">
                    <TextBlock Text="🔨" FontSize="14" />
                </Button>
                <!-- Startup project selector -->
                <ComboBox ItemsSource="{Binding ProjectNames}"
                          SelectedItem="{Binding SelectedStartupProject}"
                          MinWidth="140" MaxWidth="250" Height="26"
                          VerticalAlignment="Center" Margin="4,0"
                          FontSize="11" Background="#3C3C3C" Foreground="#CCCCCC"
                          BorderBrush="#555" Padding="6,2"
                          IsVisible="{Binding IsWorkspaceOpen}"
                          ToolTip.Tip="Startup Project" />
                <Button Width="28" Height="28" ToolTip.Tip="Run Without Debugging (Ctrl+F5)"
                        Command="{Binding RunProjectCommand}">
                    <PathIcon Width="14" Height="14" Foreground="#4EC9B0"
                              Data="M 3,1 L 13,7 L 3,13 Z" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Stop"
                        Command="{Binding StopExecutionCommand}">
                    <PathIcon Width="14" Height="14" Foreground="#F44747"
                              Data="M 2,2 L 12,2 L 12,12 L 2,12 Z" />
                </Button>
                <Border Width="1" Background="#555" Margin="4,2" />
                <Button Width="28" Height="28" ToolTip.Tip="Start Debugging (F5)"
                        Command="{Binding StartDebuggingCommand}">
                    <PathIcon Width="14" Height="14" Foreground="#89D185"
                              Data="M 3,1 L 13,7 L 3,13 Z" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Step Over (F10)"
                        Command="{Binding DebugStepOverCommand}">
                    <PathIcon Width="12" Height="12" Foreground="#75BEFF"
                              Data="M 1,6 L 4,6 L 4,3 L 8,3 L 8,6 L 11,6 L 6,11 Z" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Step Into (F11)"
                        Command="{Binding DebugStepIntoCommand}">
                    <PathIcon Width="12" Height="12" Foreground="#75BEFF"
                              Data="M 3,1 L 9,1 L 9,4 L 12,4 L 6,10 L 0,4 L 3,4 Z" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Step Out (Shift+F11)"
                        Command="{Binding DebugStepOutCommand}">
                    <PathIcon Width="12" Height="12" Foreground="#75BEFF"
                              Data="M 3,10 L 9,10 L 9,7 L 12,7 L 6,1 L 0,7 L 3,7 Z" />
                </Button>
                <Button Width="28" Height="28" ToolTip.Tip="Stop Debugging (Shift+F5)"
                        Command="{Binding StopDebuggingCommand}">
                    <PathIcon Width="14" Height="14" Foreground="#F44747"
                              Data="M 2,2 L 12,2 L 12,12 L 2,12 Z" />
                </Button>
            </StackPanel>
        </Border>

        <!-- Dockable Content Area -->
        <dc:DockControl Grid.Row="2" Layout="{Binding DockLayout}" />

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#007ACC" Padding="8,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding CurrentBranch}" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="|" Foreground="#80FFFFFF" />
                    <TextBlock Text="{Binding Editor.DiagnosticSummary}" Foreground="White" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" HorizontalAlignment="Center" Foreground="White" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding Editor.CurrentMethodInfo}" Foreground="White" FontSize="11" />
                    <TextBlock Text="|" Foreground="#80FFFFFF" />
                    <TextBlock Text="{Binding Editor.CursorLine, StringFormat='Ln {0}'}" Foreground="White" />
                    <TextBlock Text="{Binding Editor.CursorColumn, StringFormat='Col {0}'}" Foreground="White" />
                    <TextBlock Text="Spaces: 4" Foreground="White" />
                    <TextBlock Text="UTF-8" Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
